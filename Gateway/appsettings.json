{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": "Information"
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "ThisIsASuperSecretKeyForConnectSphere2026!",
    "Issuer": "ConnectSphere",
    "Audience": "ConnectSphereUsers"
  },
  "ReverseProxy": {
    "Routes": {
      "auth-public-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/users/login",
          "Methods": ["POST"]
        }
      },
      "auth-register-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/users/register",
          "Methods": ["POST"]
        }
      },
      "auth-protected-route": {
        "ClusterId": "auth-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      },
      "post-route": {
        "ClusterId": "post-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/api/posts/{**catch-all}"
        }
      },
      "feed-route": {
        "ClusterId": "feed-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/api/feed/{**catch-all}"
        }
      },
      "like-route": {
        "ClusterId": "like-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/api/likes/{**catch-all}"
        }
      },
      "follow-route": {
        "ClusterId": "follow-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/api/follows/{**catch-all}"
        }
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        }
      },
      "comment-route": {
        "ClusterId": "comment-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/api/comments/{**catch-all}"
        }
      },
      "bookmark-route": {
        "ClusterId": "bookmark-cluster",
        "AuthorizationPolicy": "Authenticated",
        "Match": {
          "Path": "/api/bookmarks/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://connectsphere-uzji.onrender.com"
          }
        }
      },
      "post-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://connectsphere-post-api-cttj.onrender.com"
          }
        }
      },
      "feed-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://connectsphere-feed-api-7r9i.onrender.com"
          }
        }
      },
      "like-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://connectsphere-like-api-m1u3.onrender.com"
          }
        }
      },
      "follow-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://connectsphere-follow-api-9dux.onrender.com"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://connectsphere-notification-api.onrender.com"
          }
        }
      },
      "comment-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://connectsphere-comment-api-is8f.onrender.com"
          }
        }
      },
      "bookmark-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "https://connectsphere-bookmark-api.onrender.com"
          }
        }
      }
    }
  }
}